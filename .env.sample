# ===================================================================
# Workspace CLI Execution Platform - 로컬 개발 환경 변수 정의서 (.env)
# ===================================================================
# 본 파일을 복사하여 `.env` 파일로 이름을 바꾼 후 실제 계정 정보를 입력하십시오.

# 1. 애플리케이션 실행 환경 (development / test / production)
APP_ENV=development

# 2. 데이터베이스 접속 설정 (PostgreSQL Connection Details)
# 형식: postgresql://[유저명]:[비밀번호]@[호스트]:[포트]/[데이터베이스명]
DATABASE_URL=postgresql://cli_user:cli_password@localhost:5432/cli_platform

# 3. CORS 허용 도메인 설정 (콤마 단위 구분 또는 전체 허용 '*')
ALLOWED_ORIGINS=*

# 4. OpenSCAD CLI 실행 파일 경로
# 기본값: openscad
# Windows 예시: C:\Program Files\OpenSCAD\openscad.exe
# Linux/macOS 예시: /usr/bin/openscad
OPENSCAD_BIN_PATH=openscad

# 5. SSE 스트리밍 토큰 암호화 비밀 키 (최소 16자 이상 강력한 임의 문자열 권장)
SSE_STREAM_TOKEN_SECRET=your-temporary-sse-stream-token-secret-key-12345

# 6. LLM 연동 설정 (Orchestrator Plan Generation)
# 로컬 개발/테스트 시 fake transport를 사용하거나 실제 OpenAI/Gemini 호환 API 주소를 적습니다.
LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
LLM_API_KEY=your-llm-api-key-here
LLM_MODEL=gpt-4o
