# ===================================================================
# Workspace CLI Execution Platform - environment template
# Keep this file and the runtime .env file ASCII-only.
# Copy this file to .env and replace all placeholder values.
# ===================================================================

# Application runtime: development, test, or production
APP_ENV=development
APP_PORT=8000

# Docker Compose PostgreSQL service credentials.
# These values are used by both the db service and the app service.
# DATABASE_URL is auto-constructed in docker-compose.yml using these variables.
POSTGRES_USER=cli_user
POSTGRES_PASSWORD=cli_password
POSTGRES_DB=cli_platform
POSTGRES_PORT=5432

# DATABASE_URL is overridden by docker-compose.yml to point to the internal db service.
# When running outside Docker (e.g., local uvicorn), set this explicitly.
DATABASE_URL=postgresql://cli_user:cli_password@localhost:5432/cli_platform

# CORS origins. Use a comma-separated list in production.
ALLOWED_ORIGINS=*

# WSL2 direct execution uses openscad from PATH.
# Docker Compose overrides this with /usr/local/bin/openscad-headless.
OPENSCAD_BIN_PATH=openscad

# Use a strong random value with at least 16 characters.
SSE_STREAM_TOKEN_SECRET=replace-with-a-strong-random-secret

# OpenAI-compatible LLM endpoint and credentials.
LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
LLM_API_KEY=replace-with-your-api-key
LLM_MODEL=gpt-4o
